# Copy this file to .env and fill in the values. The .env file is gitignored.
# Only the FastAPI backend reads these — the Flutter frontend never sees them.

# Supabase (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM providers — fill in at least the one you select on the Settings page.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub personal access token with repo read access (for private Obsidian vault repos).
GITHUB_TOKEN=
